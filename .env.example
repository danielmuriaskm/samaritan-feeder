# Intelligence Feeder Configuration

# Server
PORT=3000
NODE_ENV=development

# Database (shared with Samaritan)
# For Supabase use the SESSION pooler or a direct connection (not the 6543
# transaction pooler) for this long-lived server, and set DATABASE_SSL=true.
DATABASE_URL=postgresql://user:pass@localhost:5432/samaritan
# Enable TLS for Postgres (required by Supabase / managed PG).
DATABASE_SSL=false

# Samaritan integration
SAMARITAN_BASE_URL=http://localhost:3001
SAMARITAN_AUTH_TOKEN=your-samaritan-internal-token

# LLM provider (for text summarization and vision analysis)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Embedding provider (for semantic search)
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Unused by default. The live event spine is an in-process EventEmitter (src/bus.ts),
# so the feeder MUST run as a SINGLE machine (fly scale count 1) — two instances
# would double-poll sources and split the SSE bus. REDIS_URL is reserved for a
# future multi-instance pub/sub seam and is not read today.
REDIS_URL=

# ----- Operator console / API access control -----
# HTTP Basic password for the browser console + API. Unset => OPEN (dev only).
# Set in prod, and pair with Fly-private networking (no public IP).
CONSOLE_PASSWORD=
CONSOLE_USER=operator
# Bearer token for server-to-server callers (Samaritan radar/discovery + /ingest).
# Samaritan sends: Authorization: Bearer <this>. Bypasses the Basic console challenge.
FEEDER_SERVICE_TOKEN=

# Rate limiting and retention
MAX_EVENTS_PER_SOURCE_PER_HOUR=100
DEFAULT_RETENTION_DAYS=30
RAW_DATA_RETENTION_DAYS=7
SHODAN_API_KEY=your-shodan-api-key

# Windy webcams API
WINDY_API_KEY=your-windy-api-key
WINDY_API_KEY2=your-windy-api-key-2

# ----- Computer-vision sidecar (video intelligence) -----
# Master switch. When false, webcam/IP/traffic/weather cams use the legacy LLM path.
CV_ENABLED=false
# Base URL of the Python CV sidecar (cv-sidecar/). docker-compose: http://cv-sidecar:8800
CV_SIDECAR_URL=http://localhost:8800
# Shared bearer token for Node<->sidecar auth (must match the sidecar's CV_SIDECAR_TOKEN)
CV_SIDECAR_TOKEN=
# Per-request timeout so a slow sidecar can't stall the poll loop
CV_SIDECAR_TIMEOUT_MS=25000
# Detection confidence floor
CV_MIN_SCORE=0.35
# Comma-separated COCO classes to count (empty = people + vehicles default)
CV_DETECT_CLASSES=
# Person count at/above which a frame is flagged a crowd anomaly
CV_CROWD_THRESHOLD=25
# Optionally run the (de-identified, enum-only) vision LLM on the REDACTED thumbnail.
# Never runs for EU sources while CV_EU_HARD_GATE=true. Off by default (cost + privacy).
CV_LLM_ENRICH=false
# If the sidecar is unreachable, fall back to the legacy single-frame LLM path
CV_FALLBACK_TO_LLM=false

# ----- Clip tracking (P1): set cv.clipMode=true on a video source to enable -----
# Clip duration (s) and sampled fps pulled for tracking / line-crossing.
CV_CLIP_SECONDS=4
CV_SAMPLED_FPS=6
# A track must be seen this many frames to be confirmed (debounce).
CV_CONFIRM_FRAMES=2
# Window (ms) for cross-clip track reconciliation (parked-object dedupe).
CV_TRACK_DEDUPE_WINDOW_MS=300000
# Optional go2rtc normalization proxy (only for protocol-stubborn feeds).
GO2RTC_URL=

# ----- Alerts + artifacts (P2): rules live per-source in config.cv.rules -----
# Store a REDACTED best-frame on alert events (de-identified imagery). Off by default.
CV_STORE_ARTIFACTS=false
# Open-vocabulary detection (sidecar): CV_DETECTOR=yolo-world is OPT-IN and copyleft
# (GPL/AGPL) — run only in an isolated container. Classes for that mode:
# CV_OPENVOCAB_CLASSES=person,car,ambulance,smoke,flood

# ----- Semantic search (P2 deferred): CLIP embeddings of REDACTED alert frames -----
# Requires: pgvector Postgres image + `npm run db:migrate:semantic` + a sidecar
# built WITH_CLIP=true and started with CV_CLIP_ENABLED=true. Off by default (heavy).
CV_SEMANTIC_SEARCH=false
CV_CLIP_DIM=512
# Sidecar-side (cv-sidecar): CV_CLIP_ENABLED=true, CV_CLIP_MODEL=ViT-B-32,
# CV_CLIP_PRETRAINED=laion2b_s34b_b79k

# ----- Privacy / compliance guards (SAFE DEFAULTS — change with care) -----
VISION_REDACT_BEFORE_STORE=true
VISION_PERSIST_RAW_FRAMES=false
CV_EU_HARD_GATE=true
ALLOW_FACE_RECOGNITION=false
ALLOW_PLATE_OCR=false
ALLOW_PERSON_REID=false
ALLOW_CROSS_CAMERA_TRACKING=false
PERSIST_TRACKER_IDS=false

# ----- SSRF / stream egress -----
# Stream URLs (config.streamUrl) and crawled links are fetched server-side and
# are validated against private/reserved IP ranges (see docs/video-intelligence.md
# "Network security & SSRF"). Set true ONLY to watch a camera on the operator's
# own LAN; this disables the private-address block for the ffmpeg/yt-dlp/clip path.
ALLOW_PRIVATE_STREAM_URLS=false

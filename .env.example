# Intelligence Feeder Configuration

# Server
PORT=3000
NODE_ENV=development

# Database (shared with Samaritan)
DATABASE_URL=postgresql://user:pass@localhost:5432/samaritan

# Samaritan integration
SAMARITAN_BASE_URL=http://localhost:3001
SAMARITAN_AUTH_TOKEN=your-samaritan-internal-token

# LLM provider (for text summarization and vision analysis)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Embedding provider (for semantic search)
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Optional Redis for pub/sub between feeder instances
REDIS_URL=

# Security
FEEDER_API_KEY=change-me-in-production

# Rate limiting and retention
MAX_EVENTS_PER_SOURCE_PER_HOUR=100
DEFAULT_RETENTION_DAYS=30
RAW_DATA_RETENTION_DAYS=7

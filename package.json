{
  "name": "samaritan-feeder",
  "version": "0.1.0",
  "description": "Real-time intelligence feeder for Samaritan — social media, webcams, CCTV feeds",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "tsx migrations/run.ts",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.14.0",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.7.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
